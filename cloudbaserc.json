{
  "version": "2.0",
  "envId": "{{env.ENV_ID}}",
  "region": "ap-shanghai",
  "functions": [],
  "storages": [
    {
      "desc": "主网站存储",
      "groupName": "static",
      "acl": "public-read"
    }
  ],
  "hosting": {
    "ignore": [
      "node_modules/**",
      ".git/**",
      "README.md",
      "cloudbaserc.json"
    ]
  },
  "framework": {
    "name": "hanfu-docs",
    "plugins": {
      "client": {
        "use": "@cloudbase/framework-plugin-website",
        "inputs": {
          "buildCommand": "npm run build",
          "outputPath": "build",
          "cloudPath": "/",
          "envVariables": {}
        }
      }
    }
  }
}